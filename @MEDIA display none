.container {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  grid-template-rows: 100px 200px 100px;
  grid-template-areas:
    "header header header"
    "menu main aside"
    "footer footer footer";
}

.header {
  padding: 20px;
  background: lightblue;
  grid-area: header;
  text-align: center;
}

.menu {
  background: lightgreen;
  grid-area: menu;
  text-align: center;
  padding: 20px;
}

.main {
  background: lightyellow;
  grid-area: main;
  padding: 20px;
  display: grid;
  grid-template-columns: repeat(3, 80px);
}
.card {
  border: 2px solid black;
  padding: 20px;
  text-align: center;
  border-radius: 10px;
}

.footer {
  background: lightcoral;
  grid-area: footer;
  padding: 20px;
  text-align: center;
}

.aside {
  background-color: pink;
  padding: 20px;
  grid-area: aside;
  text-align: center;
}

@media (max-width: 768px) {
  .container {
    grid-template-columns: 1fr;

    grid-template-rows: 100px auto auto auto 100px;

    grid-template-areas:
      "header"
      "menu"
      "main"
      "footer";
  }
  .aside {
    display: none;
  }

  .main {
    grid-template-columns: 1fr;
  }
}
