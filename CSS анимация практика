@keyframes color {
  from {
    background: rgb(251, 2, 2);
  }

  to {
    background: rgb(47, 255, 0);
  }
  from {
    transform: translateX(0);
  }

  to {
    transform: translateX(500px);
  }
}

.box {
  width: 100px;
  height: 100px;

  animation: color 2s;
}

.box {
  animation: color 5s;
  animation-iteration-count: infinite;
  animation-direction: alternate;
}
