<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Document</title>
    <link rel="stylesheet" href="index.css" />
  </head>
  <body>
    <div class="container">
      <header class="header">HEADER</header>

      <nav class="menu">MENU</nav>

      <main class="main">
        <div class="card">
          <div>📦</div>
          <p>iPhone</p>
          <p>999$</p>
          <button class="button">Купить</button>
        </div>
        <div class="card">
          <div>📦</div>
          <p>iPhone</p>
          <p>999$</p>
          <button class="button">Купить</button>
        </div>
        <div class="card">
          <div>📦</div>
          <p>iPhone</p>
          <p>999$</p>
          <button class="button">Купить</button>
        </div>
      </main>

      <footer class="footer">FOOTER</footer>
    </div>
  </body>
</html>










.header {
  background-color: red;
  text-align: center;
  grid-area: header;
  padding: 20px;
}
.main {
  background-color: palegreen;
  grid-area: main;
  padding: 20px;

  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px;
}

.menu {
  background-color: rgb(108, 204, 40);
  text-align: center;
  grid-area: menu;
  padding: 20px;
}

.footer {
  background-color: aquamarine;
  text-align: center;
  grid-area: footer;
  padding: 20px;
}

.container {
  display: grid;
  grid-template-columns: 100px 1fr;
  grid-template-areas:
    "header header"
    "menu main"
    "footer footer";
}
.card {
  border: 2px solid black;
  border-radius: 10px;
  padding: 20px;
  text-align: center;
}

p {
  color: gold;
  text-align: center;
}

.button {
  background-color: green;
  color: white;
  border: 2px solid black;
  border-radius: 10px;
  padding: 10px;
  transition: 0.5s;
}
.button:hover {
  background-color: rgb(226, 229, 38);
  border: 3px solid rgb(3, 3, 3);
  border-radius: 10px;
  box-shadow: 0px 0px 20px yellow;
  transform: scale(1.1);
}

@media (max-width: 1024px) {
  .container {
    grid-template-columns: repeat(2, 1fr);
    grid-template-areas:
      "header header"
      "menu menu"
      "main main"
      "footer footer";
  }
  .main {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (max-width: 768px) {
  .container {
    grid-template-columns: 1fr;
    grid-template-areas:
      "header"
      "menu"
      "main"
      "footer";
  }
  .main {
    grid-template-columns: 1fr;
  }
}
