<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Document</title>
    <link rel="stylesheet" href="index.css" />
  </head>
  <body>
    <h1>Компьютерный магазин</h1>

    <div class="container">
      <div class="card">
        <img class="img" src="images (2).jfif" width="200px" />
        <h2>Intel i5</h2>
        <p>75$</p>
        <form>
          <button class="button" type="submit">Купить</button>
        </form>
      </div>

      <div class="card">
        <img class="img" src="images (3).jfif" width="200px" />
        <h2>RAM 16GB</h2>
        <p>80$</p>
        <form>
          <button class="button" type="submit">Купить</button>
        </form>
      </div>

      <div class="card">
        <img class="img" src="images (4).jfif " width="200px" />
        <h2>SSD 512GB</h2>
        <p>60$</p>
        <form>
          <button class="button" type="submit">Купить</button>
        </form>
      </div>
    </div>
  </body>
</html>








.container {
  display: flex;

  border-radius: 10px;
  justify-content: space-evenly;
}
body {
  background-color: burlywood;
}
h2 {
  color: wheat;
}
h1 {
  color: wheat;
  text-align: center;
}
.card {
  border: 2px solid black;
  border-radius: 15px;
  padding: 20px;
  background-color: white;
}
.img {
  border-radius: 20px;
  box-shadow: 5px 5px 10px rgb(156, 181, 31);
}

.button {
  background-color: bisque;
  border-radius: 20px;
}
.button:hover {
  background-color: whitesmoke;
  border-radius: 20px;
  box-shadow: 0px 0px 20px rgb(219, 109, 13);
}

