<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Document</title>
    <link rel="stylesheet" href="index.css" />
  </head>
  <body>
    <h1 class="title">Компьютерный магазин</h1>

    <p class="description">Лучшие комплектующие по выгодным ценам.</p>

    <button class="buy">Купить</button>
  </body>
</html>





.title {
  text-align: center;
  color: red;
}
.description {
  color: black;
  padding: 20px;
  border: 2px solid black;
}

.buy {
  background-color: green;
  color: white;
  border: 2px solid black;
  border-radius: 10px;
  padding: 10px;
}

.buy:hover {
  background-color: red;
  border: 3px solid blue;
  border-radius: 30px;
  box-shadow: 0px 0px 20px yellow;
}
